        "required": true
      },
      {
        "name": "isSlider",
        "label": "Use Image Slider?",
        "type": "boolean",
        "required": false,
        "description": "Turn this on to use multiple slides. Turn it off to use one background image.",
        "initialValue": true
      },
      {
        "name": "backgroundImage",
        "label": "Background Image",
        "type": "image",
        "required": true,
        "hidden_condition": {
          "field": "isSlider",
          "operator": "eq",
          "value": true
        }
      },
      {
        "name": "backgroundImageAltText",
        "label": "Background Image Alt Text",
        "type": "string",
        "required": true,
        "hidden_condition": {
          "field": "isSlider",
          "operator": "eq",
          "value": true
        }
      },
      {
        "name": "slides",
        "label": "Slides",
        "type": "array",
        "required": true,
        "description": "Optional. Example: Image 1, Main Banner, Promo Slide.",
        "hidden_condition": {
          "field": "isSlider",
          "operator": "eq",
          "value": false
        },
        "of_type": "object",
        "fields": [
          {
            "name": "label",
            "label": "Slide Label",
            "type": "string",
            "required": false,
            "description": "Optional. Example: Image 1, Main Banner, Promo Slide."
          },
          {
            "name": "image",
            "label": "Background Image",
            "type": "image",
            "required": true
          },
          {
            "name": "altText",
            "label": "Alt Text",
            "type": "string",
            "required": true
          }
        ]
      }
    ]
  },
